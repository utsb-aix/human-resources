<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>谷口星河さん アサイン提案資料</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Playfair+Display:wght@400;700&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f3ee;
    --surface: #ffffff;
    --surface2: #f0ede6;
    --ink: #1a1714;
    --ink2: #4a4540;
    --ink3: #7a736a;
    --accent: #2d5a3d;
    --accent2: #4a8c60;
    --accent-light: #e8f0eb;
    --gold: #b5893a;
    --gold-light: #f5ecd6;
    --border: #ddd8ce;
    --radius: 4px;
    --shadow: 0 2px 16px rgba(26,23,20,0.08);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Noto Sans JP', sans-serif; background: var(--bg); color: var(--ink); font-size: 15px; line-height: 1.75; }

  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(245,243,238,0.95); backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 0 24px; display: flex; align-items: center; gap: 8px;
    height: 48px; overflow-x: auto; scrollbar-width: none;
  }
  nav::-webkit-scrollbar { display: none; }
  nav a {
    font-size: 11px; font-weight: 500; letter-spacing: 0.06em;
    color: var(--ink3); text-decoration: none; white-space: nowrap;
    padding: 4px 10px; border-radius: 20px; transition: all 0.2s;
  }
  nav a:hover { background: var(--accent); color: #fff; }

  section {
    min-height: 100vh; padding: 96px 24px 72px;
    display: flex; flex-direction: column; justify-content: center;
    max-width: 900px; margin: 0 auto;
    border-bottom: 1px solid var(--border);
  }
  section:last-child { border-bottom: none; }

  /* COVER */
  #cover {
    min-height: 100vh; background: var(--accent); color: #fff;
    max-width: 100%; padding: 0; display: grid; place-items: center;
    position: relative; overflow: hidden;
  }
  #cover::before {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(255,255,255,0.03) 40px, rgba(255,255,255,0.03) 41px);
  }
  .cover-inner { text-align: center; padding: 48px 24px; position: relative; }
  .cover-label { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.2em; opacity: 0.6; text-transform: uppercase; margin-bottom: 32px; }
  .cover-name { font-family: 'Playfair Display', serif; font-size: clamp(48px, 10vw, 88px); line-height: 1.1; margin-bottom: 8px; }
  .cover-name-ja { font-family: 'Noto Serif JP', serif; font-size: clamp(16px, 3vw, 22px); opacity: 0.7; letter-spacing: 0.15em; margin-bottom: 40px; }
  .cover-role { font-family: 'Noto Serif JP', serif; font-size: clamp(13px, 2vw, 18px); line-height: 1.8; opacity: 0.9; margin-bottom: 48px; }
  .cover-role strong { opacity: 1; font-weight: 700; }
  .cover-notice { font-size: 12px; opacity: 0.6; border: 1px solid rgba(255,255,255,0.3); border-radius: 4px; padding: 8px 16px; display: inline-block; }
  .cover-pills { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-top: 40px; }
  .cover-pill { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.25); border-radius: 20px; padding: 6px 18px; font-size: 12px; letter-spacing: 0.05em; }
  .summary-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin-top: 40px; }
  @media(max-width:600px){ .summary-row { grid-template-columns: 1fr; } }
  .summary-pill { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .summary-pill .sp-num { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.15em; color: var(--gold); margin-bottom: 6px; }
  .summary-pill h3 { font-size: 15px; font-weight: 700; margin-bottom: 4px; }
  .summary-pill p { font-size: 12px; color: var(--ink3); }

  /* COMMON */
  .page-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.25em; color: var(--ink3); text-transform: uppercase; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
  .page-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .sec-title { font-family: 'Noto Serif JP', serif; font-size: clamp(22px, 4vw, 32px); font-weight: 700; line-height: 1.4; margin-bottom: 8px; }
  .sec-sub { color: var(--ink3); font-size: 14px; margin-bottom: 40px; line-height: 1.6; }
  .divider { height: 1px; background: var(--border); margin: 32px 0; }

  /* PROFILE */
  .profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media(max-width:600px){ .profile-grid { grid-template-columns: 1fr; } }
  .profile-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px 24px; box-shadow: var(--shadow); }
  .profile-card h4 { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.15em; color: var(--ink3); text-transform: uppercase; margin-bottom: 6px; }
  .profile-card p { font-size: 14px; line-height: 1.6; }
  .profile-card .val { font-weight: 600; color: var(--ink); }
  .org-block { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; margin-top: 24px; }
  .org-block h4 { font-family: 'Noto Serif JP', serif; font-size: 16px; font-weight: 700; margin-bottom: 12px; color: var(--accent); }
  .org-block ul { list-style: none; padding: 0; }
  .org-block li { font-size: 13px; padding: 4px 0; border-bottom: 1px dashed var(--border); color: var(--ink2); }
  .org-block li:last-child { border-bottom: none; }
  .org-block li strong { color: var(--accent); }

  /* SKILLS TABLE */
  .skill-table { width: 100%; border-collapse: collapse; background: var(--surface); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); margin-bottom: 24px; }
  .skill-table th { background: var(--accent); color: #fff; font-size: 12px; font-weight: 600; padding: 10px 14px; text-align: left; }
  .skill-table td { padding: 10px 14px; font-size: 13px; border-bottom: 1px solid var(--border); color: var(--ink2); vertical-align: top; }
  .skill-table tr:last-child td { border-bottom: none; }
  .skill-level { display: flex; gap: 3px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); }
  .dot.on { background: var(--accent); }

  /* STRENGTHS */
  .strength-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
  .strength-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; position: relative; overflow: hidden; }
  .strength-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--accent); }
  .strength-num { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--accent); letter-spacing: 0.1em; margin-bottom: 8px; }
  .strength-card h4 { font-size: 14px; font-weight: 700; margin-bottom: 8px; }
  .strength-card p { font-size: 13px; color: var(--ink2); line-height: 1.6; }
  .strength-card .person-comment { font-size: 11px; color: var(--gold); font-style: italic; margin-top: 8px; padding: 6px 8px; background: var(--gold-light); border-radius: 2px; }

  /* WCM */
  .wcm-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
  @media(max-width:600px){ .wcm-grid { grid-template-columns: 1fr; } }
  .wcm-card { background: var(--accent); color: #fff; border-radius: var(--radius); padding: 28px 20px; text-align: center; }
  .wcm-card .wcm-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.3em; opacity: 0.7; margin-bottom: 6px; }
  .wcm-card h4 { font-family: 'Noto Serif JP', serif; font-size: 13px; font-weight: 600; margin-bottom: 10px; opacity: 0.85; }
  .wcm-card p { font-size: 13px; line-height: 1.7; opacity: 0.9; }

  /* EVALUATION */
  .eval-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
  .eval-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .eval-num { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--gold); letter-spacing: 0.15em; margin-bottom: 8px; }
  .eval-card h4 { font-size: 13px; font-weight: 700; margin-bottom: 8px; }
  .eval-card ul { list-style: none; padding: 0; }
  .eval-card li { font-size: 12px; color: var(--ink2); padding: 3px 0; border-bottom: 1px dashed var(--border); }
  .eval-card li:last-child { border-bottom: none; }
  .eval-card .quote { font-size: 11px; color: var(--accent); font-style: italic; margin-top: 10px; padding: 8px 10px; background: var(--accent-light); border-left: 2px solid var(--accent); border-radius: 2px; }
  .self-score { display: flex; align-items: center; gap: 6px; margin-top: 8px; font-size: 11px; color: var(--ink3); }

  /* APTITUDE */
  .apt-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; }
  .apt-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .apt-num { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--ink3); letter-spacing: 0.15em; margin-bottom: 6px; }
  .apt-card h4 { font-size: 13px; font-weight: 700; margin-bottom: 6px; }
  .apt-card .scene { font-size: 11px; color: var(--accent); font-weight: 600; margin-bottom: 6px; }
  .apt-card p { font-size: 12px; color: var(--ink2); line-height: 1.6; }
  .apt-card .self { font-size: 11px; color: var(--gold); font-style: italic; margin-top: 8px; padding: 6px 8px; background: var(--gold-light); border-radius: 2px; }

  /* HOPES */
  .hopes-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px,1fr)); gap: 14px; }
  .hope-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; display: flex; gap: 14px; }
  .hope-num { font-family: 'DM Mono', monospace; font-size: 22px; color: var(--accent); font-weight: 300; line-height: 1; min-width: 28px; }
  .hope-card h4 { font-size: 13px; font-weight: 700; margin-bottom: 4px; }
  .hope-card p { font-size: 12px; color: var(--ink2); line-height: 1.6; }

  /* VALUE ICONS */
  .value-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px,1fr)); gap: 12px; margin-top: 8px; }
  .value-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 14px; text-align: center; }
  .value-card .vi { font-size: 26px; margin-bottom: 6px; }
  .value-card h4 { font-size: 11px; font-weight: 700; color: var(--ink3); margin-bottom: 4px; }
  .value-card p { font-size: 12px; color: var(--ink); }

  /* POSITION */
  .position-hero { background: var(--accent); color: #fff; border-radius: var(--radius); padding: 40px; text-align: center; margin-bottom: 24px; }
  .position-hero .pos-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.2em; opacity: 0.6; margin-bottom: 12px; }
  .position-hero h3 { font-family: 'Noto Serif JP', serif; font-size: clamp(16px, 2.5vw, 24px); line-height: 1.6; font-weight: 700; margin-bottom: 10px; }
  .position-hero .future { font-size: 13px; opacity: 0.75; }
  .tasks-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; }
  .task-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; display: flex; gap: 14px; align-items: flex-start; }
  .task-num { font-family: 'DM Mono', monospace; font-size: 18px; color: var(--accent); font-weight: 400; line-height: 1; min-width: 28px; }
  .task-card h4 { font-size: 13px; font-weight: 700; margin-bottom: 4px; }
  .task-card p { font-size: 12px; color: var(--ink2); line-height: 1.6; }

  /* PHASE */
  .phase-list { display: flex; flex-direction: column; gap: 0; }
  .phase-item { display: flex; gap: 24px; align-items: flex-start; padding: 24px 0; border-bottom: 1px solid var(--border); }
  .phase-item:last-child { border-bottom: none; }
  .phase-dot { width: 36px; height: 36px; border-radius: 50%; background: var(--accent); color: #fff; font-family: 'DM Mono', monospace; font-size: 13px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
  .phase-content h4 { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
  .phase-content .phase-time { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--gold); letter-spacing: 0.1em; margin-bottom: 6px; }
  .phase-content p { font-size: 13px; color: var(--ink2); line-height: 1.6; }

  /* COST */
  .cost-table { width: 100%; border-collapse: collapse; background: var(--surface); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); margin-bottom: 24px; }
  .cost-table th { background: var(--accent); color: #fff; font-size: 12px; font-weight: 600; letter-spacing: 0.05em; padding: 12px 16px; text-align: left; }
  .cost-table td { padding: 12px 16px; font-size: 13px; border-bottom: 1px solid var(--border); color: var(--ink2); }
  .cost-table tr:last-child td { border-bottom: none; }
  .cost-table td strong { color: var(--ink); font-weight: 700; }

  /* CONDITIONS */
  .cond-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
  .cond-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .cond-icon { font-size: 24px; margin-bottom: 8px; }
  .cond-card h4 { font-size: 12px; font-weight: 700; color: var(--ink3); margin-bottom: 4px; }
  .cond-card p { font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
  .cond-card span { font-size: 12px; color: var(--ink3); }
  .caution-box { background: var(--gold-light); border: 1px solid var(--gold); border-radius: var(--radius); padding: 16px 20px; font-size: 13px; color: var(--ink2); margin-top: 20px; line-height: 1.7; }

  /* COMMENT */
  .comment-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px; box-shadow: var(--shadow); position: relative; }
  .comment-box::before { content: '"'; font-family: 'Playfair Display', serif; font-size: 96px; color: var(--accent); opacity: 0.15; position: absolute; top: -8px; left: 20px; line-height: 1; }
  .comment-box blockquote { font-family: 'Noto Serif JP', serif; font-size: 15px; line-height: 1.9; color: var(--ink2); position: relative; z-index: 1; margin-bottom: 12px; }
  .comment-box .comment-by { font-size: 12px; color: var(--ink3); font-family: 'DM Mono', monospace; letter-spacing: 0.05em; }

  /* CLOSING */
  #closing { background: var(--ink); color: #fff; max-width: 100%; padding: 96px 24px; text-align: center; }
  .closing-inner { max-width: 700px; margin: 0 auto; }
  .closing-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.3em; opacity: 0.5; text-transform: uppercase; margin-bottom: 24px; }
  .closing-title { font-family: 'Noto Serif JP', serif; font-size: clamp(22px, 4vw, 36px); font-weight: 700; line-height: 1.5; margin-bottom: 24px; }
  .closing-body { font-size: 14px; opacity: 0.75; line-height: 1.9; margin-bottom: 40px; }
  .key-message { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); border-radius: 4px; padding: 28px 32px; margin: 32px 0; text-align: left; }
  .key-message .km-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.2em; opacity: 0.5; margin-bottom: 12px; }
  .key-message p { font-family: 'Noto Serif JP', serif; font-size: 15px; line-height: 1.9; opacity: 0.9; }
  .approval-box { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2); border-radius: 4px; padding: 28px; margin-top: 32px; text-align: left; }
  .approval-box h4 { font-size: 13px; font-weight: 700; opacity: 0.6; margin-bottom: 16px; letter-spacing: 0.05em; }
  .approval-box p { font-size: 14px; line-height: 2; }
  .approval-box strong { color: #9de0b8; }
  .meta { margin-top: 48px; font-size: 11px; opacity: 0.35; font-family: 'DM Mono', monospace; letter-spacing: 0.08em; }

  /* NEGATIVE WILL */
  .nwill-box { background: #fff8f0; border: 1px solid #e8c9a0; border-radius: var(--radius); padding: 20px 24px; margin-top: 24px; }
  .nwill-box h4 { font-size: 13px; font-weight: 700; color: #a0623a; margin-bottom: 10px; }
  .nwill-box ul { list-style: none; padding: 0; }
  .nwill-box li { font-size: 13px; color: var(--ink2); padding: 4px 0; border-bottom: 1px dashed #e8c9a0; }
  .nwill-box li:last-child { border-bottom: none; }
  .nwill-box li::before { content: '⚠ '; opacity: 0.6; }

  /* CERTS */
  .cert-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px; }
  .cert-tag { background: var(--accent-light); border: 1px solid var(--accent2); color: var(--accent); border-radius: 20px; padding: 4px 14px; font-size: 12px; }
</style>
</head>
